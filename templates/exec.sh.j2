#!/usr/bin/env bash
# DonaNet — exec script (opens a shell inside the container)
# Profile  : {{ profile_name }}
# Generated by configure.py — do NOT edit manually.
#
# Usage    : ./exec.sh [command]
# Examples :
#   ./exec.sh                    — opens bash
#   ./exec.sh python donanet.py --help
#   ./exec.sh ls /app/weights

cd "{{ profile_dir }}"

_CMD="{{ compose_cmd }}"

CMD="${@:-bash}"

COMPOSE_DISABLE_ENV_FILE=1 $_CMD run --rm --entrypoint "" donanet $CMD
