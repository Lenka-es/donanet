# DonaNet — GPU overlay
# Profile : {{ config.profile_name }}
# Generated by configure.py — do NOT edit manually.
#
# Apply together with docker-compose.yml:
#   docker compose -f docker-compose.yml -f docker-compose.gpu.yml run --rm donanet train ...
#
# Requires NVIDIA Container Toolkit on the host:
#   https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/install-guide.html

name: donanet-{{ config.profile_name }}

services:
  donanet:
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
