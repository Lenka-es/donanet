#!/usr/bin/env bash
# DonaNet — build script
# Profile : {{ profile_name }}
# Generated by configure.py — do NOT edit manually.

cd "{{ profile_dir }}"

_CMD="{{ compose_cmd }}"

show_banner() {
cat <<'DONANET_BANNER'
{{ banner }}
DONANET_BANNER
}

show_help() {
    show_banner
cat <<'HELP_EOF'
Usage: build.sh [-h|--help] [-- docker-compose-build-flags]

Flags:
  -h, --help   Show this message

Docker compose build flags (after --):
  --no-cache   Build without cache
  --pull       Always pull a newer version of the base image

Examples:
  ./build.sh
  ./build.sh -- --no-cache
  ./build.sh -- --pull
HELP_EOF
}

BUILD_ARGS=()
AFTER_SEP=false

for arg in "$@"; do
    [[ "$arg" == "--" ]]         && { AFTER_SEP=true; continue; }
    [[ "$AFTER_SEP" == "true" ]] && { BUILD_ARGS+=("$arg"); continue; }
    case "$arg" in
        -h|--help) show_help; exit 0 ;;
        *) BUILD_ARGS+=("$arg") ;;
    esac
done

show_banner
echo "Building DonaNet image for profile: {{ profile_name }}"
echo ""

COMPOSE_DISABLE_ENV_FILE=1 $_CMD build "${BUILD_ARGS[@]}"
