#!/usr/bin/env bash
# DonaNet — info script
# Profile : {{ profile_name }}
# Generated by configure.py — do NOT edit manually.
#
# Shows available weights and dataset summary.

cd "{{ profile_dir }}"

_CMD="{{ compose_cmd }}"

echo "── DonaNet info  (profile: {{ profile_name }}) ─────────────────────"
echo ""
COMPOSE_DISABLE_ENV_FILE=1 $_CMD run --rm donanet info
echo ""
echo "── Dataset partitions ──────────────────────────────────────────────"
echo ""
COMPOSE_DISABLE_ENV_FILE=1 $_CMD run --rm donanet list-datasets
